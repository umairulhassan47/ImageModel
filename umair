{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.6.6","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":28755,"isInternetEnabled":false,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# transformers is pinned to be safe; do NOT touch tensorflow on a Kaggle\n# TPU image — its torch_xla/runtime build is interdependent with the\n# preinstalled TF and reinstalling TF can destabilize the environment.\n!pip install -q \"transformers>=4.40\" tqdm\n\n# ============================================================\n#  GardenMate — ViT-Base Plant Species Classifier\n#  Production Fine-tuning Script for Kaggle TPU v5e-8\n#  v6.0 — App-integration + correctness pass\n#\n#  Fixes vs v6.0 (this version, v6.1):\n#  [FIX-21] scan_dataset() per-class balancing: CFG.MAX_PER_CLASS caps\n#           large classes by SEEDED RANDOM sampling (not truncation) so\n#           the kept subset preserves the folder's angle/source mix;\n#           CFG.MIN_PER_CLASS drops non-viable tiny classes and reindexes\n#           labels. Both reproducible via CFG.SEED.\n#  [FIX-22] persistent_workers + prefetch_factor on DataLoaders when\n#           num_workers > 0 (off on TPU) — no per-epoch worker respawn.\n#  [FIX-23] Removed the redundant per-batch xm.mark_step() inside\n#           evaluate(); keep only the end-of-loop sync (matches train).\n#  [FIX-24] predict() reuses a cached val transform (get_val_transform)\n#           instead of rebuilding transforms.Compose() every call.\n#  [FIX-25] Optional classifier-head dropout (CFG.HEAD_DROPOUT) added via\n#           a forward-pre-hook on model.classifier. No params/buffers, so\n#           the saved state_dict and from_pretrained() export are byte-\n#           identical; dropout is a no-op at eval, so the app is unaffected.\n#\n#  Fixes vs v5.1 (in v6.0):\n#  [FIX-12] Clean HuggingFace export (model + processor) to a\n#           dedicated dir so the app can call from_pretrained()\n#           directly. v5.1's pytorch_model.bin was a wrapped payload\n#           dict that from_pretrained() silently re-initialized.\n#  [FIX-13] TPU-safe progress bar: no per-batch .item() sync\n#           (v5.1's tqdm postfix synced every step, defeating FIX-2).\n#  [FIX-14] Resume is now wired in. A 'last' checkpoint is saved every\n#           epoch; CFG.RESUME picks up the exact stage/epoch/optimizer/\n#           scheduler state. v5.1 had the resume fn but never called it.\n#  [FIX-15] label2id values are ints (were strings → wrong-type lookups).\n#  [FIX-16] Sample-weighted loss averaging (was per-batch-count, which\n#           mis-weights a partial final eval batch).\n#  [FIX-17] scheduler.step() skipped when the AMP scaler skips the\n#           optimizer step (inf/nan batch), keeping LR aligned to steps.\n#  [FIX-18] Modern AMP API (torch.amp.*) with a fallback shim for\n#           older torch; torch.cuda.amp.* was deprecated.\n#  [FIX-19] Aspect-preserving val/test transform (Resize 256 + CenterCrop)\n#           and RandomResizedCrop for train (was a square squash).\n#           RandomVerticalFlip dropped (unnatural for potted plants).\n#  [FIX-20] Removed the no-op copytree to /kaggle/output; outputs and the\n#           HF export already live under /kaggle/working.\n#\n#  Carried over from v5.1 (still correct):\n#  [FIX-1..11]  loader unpack, TPU tensor-accumulated accuracy,\n#               patience reset at Stage 2, single mark_step path,\n#               RandomErasing value='random', processor singleton,\n#               zero_division=0, multi-subdir data resolution.\n# ============================================================\n\nimport os\nimport json\nimport warnings\nimport random\nimport time\n\n# ── XLA_USE_BF16 must be set before ANY imports / ops ────────\n# Still functional on current torch_xla (emits a deprecation notice on\n# the newest builds). Left as-is deliberately: changing TPU precision\n# handling risks breaking the Kaggle TPU runtime.\nos.environ[\"XLA_USE_BF16\"] = \"1\"\n\nimport numpy as np\nimport torch\nimport torch.nn as nn\nfrom torch.utils.data import Dataset, DataLoader, WeightedRandomSampler\nfrom torchvision import transforms\nfrom PIL import Image\nfrom pathlib import Path\nfrom collections import Counter\n\nfrom transformers import (\n    ViTForImageClassification,\n    ViTImageProcessor,\n    get_cosine_schedule_with_warmup,\n)\nfrom torch.optim import AdamW\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import classification_report, confusion_matrix\nfrom tqdm import tqdm\n\nwarnings.filterwarnings(\"ignore\")\n\n\n# ════════════════════════════════════════════════════════════\n# 0.  DEVICE SETUP  —  TPU → GPU → CPU  (auto-detect)\n# ════════════════════════════════════════════════════════════\ndef setup_device():\n    try:\n        import torch_xla.core.xla_model as xm\n        from torch_xla.distributed.parallel_loader import MpDeviceLoader\n        device = xm.xla_device()\n        print(f\"✅ TPU detected: {device}\")\n        return device, \"tpu\", xm, MpDeviceLoader\n    except Exception:\n        pass\n\n    if torch.cuda.is_available():\n        device = torch.device(\"cuda\")\n        print(f\"✅ GPU detected: {torch.cuda.get_device_name(0)}\")\n        return device, \"gpu\", None, None\n\n    print(\"⚠️  No accelerator found — running on CPU (slow)\")\n    return torch.device(\"cpu\"), \"cpu\", None, None\n\n\nDEVICE, DEVICE_TYPE, xm, MpDeviceLoader = setup_device()\n\n# ── AMP setup  [FIX-18] ──────────────────────────────────────\n# Modern torch.amp API with a fallback to the deprecated torch.cuda.amp\n# for older torch. FP16 only active on CUDA; TPU precision via XLA_USE_BF16.\nUSE_AMP = (DEVICE_TYPE == \"gpu\")\ntry:\n    from torch.amp import GradScaler as _GradScaler\n    from torch.amp import autocast as _autocast\n\n    def make_scaler():\n        try:\n            return _GradScaler(\"cuda\", enabled=USE_AMP)\n        except TypeError:                       # older positional signature\n            return _GradScaler(enabled=USE_AMP)\n\n    def amp_autocast():\n        return _autocast(\"cuda\")\nexcept Exception:                                # very old torch\n    def make_scaler():\n        return torch.cuda.amp.GradScaler(enabled=USE_AMP)\n\n    def amp_autocast():\n        return torch.cuda.amp.autocast()\n\nscaler = make_scaler()\n\n\n# ════════════════════════════════════════════════════════════\n# 1.  ViTImageProcessor SINGLETON  [FIX-6]\n# ════════════════════════════════════════════════════════════\n_PROCESSOR: \"ViTImageProcessor | None\" = None\n\n\ndef get_processor(model_name: str) -> ViTImageProcessor:\n    \"\"\"Return cached processor; load from HuggingFace Hub only once.\"\"\"\n    global _PROCESSOR\n    if _PROCESSOR is None:\n        _PROCESSOR = ViTImageProcessor.from_pretrained(model_name)\n        print(f\"📦 ViTImageProcessor loaded: {model_name}\")\n    return _PROCESSOR\n\n\n# ════════════════════════════════════════════════════════════\n# 2.  DATA_DIR  — runtime-safe path resolution  [FIX-8]\n# ════════════════════════════════════════════════════════════\nVALID_EXT = {\".jpg\", \".jpeg\", \".png\", \".webp\", \".bmp\"}\n\n\ndef resolve_data_dir(base: str) -> str:\n    base = Path(base)\n    if not base.exists():\n        raise RuntimeError(f\"Base path does not exist: {base}\")\n\n    subdirs = [d for d in base.iterdir() if d.is_dir()]\n    if not subdirs:\n        raise RuntimeError(f\"No subdirectories found under {base}\")\n\n    # Check up to 5 subdirs — avoids false-negative from empty/DS_Store dir\n    sample_dirs = subdirs[:5]\n    has_images_directly = any(\n        f.suffix.lower() in VALID_EXT\n        for d in sample_dirs\n        for f in d.iterdir()\n        if f.is_file()\n    )\n\n    if has_images_directly:\n        print(f\"📁 DATA_DIR resolved: {base}\")\n        print(f\"   → {len(subdirs)} class folders found\")\n        return str(base)\n\n    # One level deeper\n    deeper_subdirs = [d for d in subdirs[0].iterdir() if d.is_dir()]\n    if deeper_subdirs:\n        print(f\"📁 DATA_DIR resolved (1 level down): {subdirs[0]}\")\n        print(f\"   → {len(deeper_subdirs)} class folders found\")\n        return str(subdirs[0])\n\n    raise RuntimeError(\n        f\"Cannot locate class folders under {base}. \"\n        f\"Contents: {list(base.iterdir())[:10]}\"\n    )\n\n\n# ════════════════════════════════════════════════════════════\n# 3.  CONFIG  — single source of truth\n# ════════════════════════════════════════════════════════════\nclass CFG:\n    # ── Paths ─────────────────────────────────────────────────\n    DATA_BASE   = \"/kaggle/input/datasets/iumairulhassan/plant-species-umair/house_plant_species\"\n    OUTPUT_DIR  = \"/kaggle/working/gardenmate_model\"\n    EXPORT_DIR  = \"/kaggle/working/gardenmate_model/hf_export\"   # [FIX-12] app-ready\n    LOG_FILE    = \"/kaggle/working/training_log.json\"\n\n    # ── Model ─────────────────────────────────────────────────\n    MODEL_NAME  = \"google/vit-base-patch16-224-in21k\"\n    IMAGE_SIZE  = 224\n\n    # ── Data split ────────────────────────────────────────────\n    VAL_RATIO   = 0.15\n    TEST_RATIO  = 0.15\n    SEED        = 42\n\n    # ── Per-class balancing  [FIX-21] ─────────────────────────\n    # MAX_PER_CLASS : ceiling. Classes above it are randomly down-sampled\n    #                 (seeded) so angle/source mix is preserved. None = off.\n    #                 The WeightedRandomSampler already equalizes exposure,\n    #                 so this is a compute trim, not an accuracy lever.\n    # MIN_PER_CLASS : floor. Classes strictly below it are DROPPED and the\n    #                 label space is reindexed contiguously. Protects the\n    #                 stratified split and removes non-viable classes.\n    MAX_PER_CLASS = 1000\n    MIN_PER_CLASS = 20\n    # Advisory only: warn (don't drop) about kept classes below this, since\n    # they'll be the weakest-supported even though they're viable.\n    WEAK_CLASS_WARN = 150\n\n    # ── Regularization  [FIX-25] ──────────────────────────────\n    # Dropout on the CLS embedding just before the classifier head. Helps\n    # the many small per-class species. 0.0 disables. Inactive at eval, so\n    # the exported model / app inference are unaffected.\n    HEAD_DROPOUT = 0.1\n\n    # ── Two-stage training ────────────────────────────────────\n    STAGE1_EPOCHS  = 3     # frozen backbone — head only\n    STAGE2_EPOCHS  = 12    # full fine-tune\n    TOTAL_EPOCHS   = STAGE1_EPOCHS + STAGE2_EPOCHS\n\n    # ── Optimizer ─────────────────────────────────────────────\n    HEAD_LR         = 5e-4\n    BACKBONE_LR     = 5e-5\n    WEIGHT_DECAY    = 0.01\n    WARMUP_RATIO    = 0.06\n    GRAD_CLIP       = 1.0\n    LABEL_SMOOTHING = 0.1\n\n    # ── DataLoader ────────────────────────────────────────────\n    BATCH_SIZE  = 32\n\n    # ── Early stopping ────────────────────────────────────────\n    PATIENCE    = 5\n\n    # ── Resume / skip control ─────────────────────────────────\n    # SKIP_TRAINING : skip training entirely, go straight to test eval\n    #                 using the best checkpoint (use after kernel restart\n    #                 when training is fully complete).\n    # RESUME        : continue an interrupted run from the 'last' checkpoint\n    #                 (exact stage/epoch/optimizer/scheduler state). [FIX-14]\n    SKIP_TRAINING = False\n    RESUME        = False\n\n\n# num_workers: 0 on TPU (non-zero triggers XLA/MpDeviceLoader conflicts),\n# 2 on GPU/CPU.\nNUM_WORKERS = 0 if DEVICE_TYPE == \"tpu\" else 2\n\n# Checkpoint paths\nBEST_CKPT = f\"{CFG.OUTPUT_DIR}/pytorch_model.bin\"        # best weights (inference)\nLAST_CKPT = f\"{CFG.OUTPUT_DIR}/last_checkpoint.bin\"      # full state (resume)\n\n\n# ════════════════════════════════════════════════════════════\n# 4.  REPRODUCIBILITY\n# ════════════════════════════════════════════════════════════\ndef set_seed(seed: int):\n    random.seed(seed)\n    np.random.seed(seed)\n    torch.manual_seed(seed)\n    if torch.cuda.is_available():\n        torch.cuda.manual_seed_all(seed)\n    os.environ[\"PYTHONHASHSEED\"] = str(seed)\n\nset_seed(CFG.SEED)\n\n\n# ════════════════════════════════════════════════════════════\n# 5.  DATASET\n# ════════════════════════════════════════════════════════════\nclass PlantDataset(Dataset):\n    \"\"\"\n    Lightweight dataset. Stores (path, label) pairs.\n    Each instance owns its sample list and transform —\n    no shared mutable state between train/val/test splits.\n    \"\"\"\n    def __init__(self, samples: list, transform, classes: list,\n                 class_to_idx: dict):\n        self.samples      = samples\n        self.transform    = transform\n        self.classes      = classes\n        self.class_to_idx = class_to_idx\n        self.idx_to_class = {v: k for k, v in class_to_idx.items()}\n\n    def __len__(self):\n        return len(self.samples)\n\n    def __getitem__(self, idx):\n        img_path, label = self.samples[idx]\n        try:\n            image = Image.open(img_path).convert(\"RGB\")\n        except Exception:\n            # Fallback: blank image — keeps training alive on corrupt files\n            image = Image.new(\"RGB\", (CFG.IMAGE_SIZE, CFG.IMAGE_SIZE))\n        return self.transform(image), label\n\n\ndef scan_dataset(data_dir: str):\n    \"\"\"\n    Scan data_dir once and apply per-class balancing  [FIX-21].\n\n    Order of operations:\n      1. Gather sorted file lists per raw class folder.\n      2. MIN_PER_CLASS: drop classes strictly below the floor (non-viable).\n      3. Re-sort surviving classes and assign contiguous label indices.\n      4. MAX_PER_CLASS: seeded RANDOM down-sample of over-full classes.\n         Random (not first-N) so the kept subset keeps the folder's\n         angle/source distribution; seeded by CFG.SEED for reproducibility.\n\n    Returns (all_samples, classes, class_to_idx).\n    \"\"\"\n    data_dir = Path(data_dir)\n    raw_classes = sorted([d.name for d in data_dir.iterdir() if d.is_dir()])\n    if not raw_classes:\n        raise RuntimeError(f\"No class folders found in {data_dir}\")\n\n    rng = random.Random(CFG.SEED)          # local, deterministic, independent\n\n    # 1. sorted file list per class (sorted → reproducible sampling)\n    files_by_class = {}\n    for cls in raw_classes:\n        cls_dir = data_dir / cls\n        files = sorted(\n            str(f) for f in cls_dir.iterdir()\n            if f.is_file() and f.suffix.lower() in VALID_EXT\n        )\n        files_by_class[cls] = files\n\n    raw_counts = {c: len(f) for c, f in files_by_class.items()}\n\n    # 2. MIN_PER_CLASS — drop non-viable classes\n    dropped = []\n    if CFG.MIN_PER_CLASS:\n        dropped = sorted(c for c, n in raw_counts.items() if n < CFG.MIN_PER_CLASS)\n        for c in dropped:\n            del files_by_class[c]\n\n    if not files_by_class:\n        raise RuntimeError(\n            f\"All classes fell below MIN_PER_CLASS={CFG.MIN_PER_CLASS}. \"\n            f\"Lower the floor or check the data path.\"\n        )\n\n    # 3. reindex surviving classes contiguously (0..N-1)\n    classes      = sorted(files_by_class.keys())\n    class_to_idx = {c: i for i, c in enumerate(classes)}\n\n    # 4. MAX_PER_CLASS — seeded random down-sample, then build samples\n    all_samples = []\n    capped = []\n    for cls in classes:\n        files = files_by_class[cls]\n        if CFG.MAX_PER_CLASS and len(files) > CFG.MAX_PER_CLASS:\n            files = rng.sample(files, CFG.MAX_PER_CLASS)   # representative subset\n            capped.append(cls)\n        for f in files:\n            all_samples.append((f, class_to_idx[cls]))\n\n    # ── Report ────────────────────────────────────────────────\n    print(f\"📦 Scanned: {sum(raw_counts.values())} raw images | \"\n          f\"{len(raw_classes)} raw classes\")\n    if dropped:\n        print(f\"🗑️  Dropped {len(dropped)} class(es) < MIN_PER_CLASS=\"\n              f\"{CFG.MIN_PER_CLASS}: \"\n              + \", \".join(f\"{c}({raw_counts[c]})\" for c in dropped))\n    if capped:\n        print(f\"✂️  Capped {len(capped)} class(es) at MAX_PER_CLASS=\"\n              f\"{CFG.MAX_PER_CLASS} via seeded random sampling.\")\n    print(f\"✅ Using: {len(all_samples)} images | {len(classes)} classes\")\n\n    counts = Counter(lbl for _, lbl in all_samples)\n    min_c  = min(counts.values())\n    max_c  = max(counts.values())\n    print(f\"📊 Class balance — min: {min_c} | max: {max_c} | \"\n          f\"ratio: {max_c / min_c:.1f}×\")\n\n    # Advisory: viable but weak classes (sampler oversamples these heavily)\n    idx_to_class = {i: c for c, i in class_to_idx.items()}\n    weak = sorted(\n        ((cnt, idx_to_class[lbl]) for lbl, cnt in counts.items()\n         if cnt < CFG.WEAK_CLASS_WARN)\n    )\n    if weak:\n        print(f\"⚠️  {len(weak)} class(es) below WEAK_CLASS_WARN=\"\n              f\"{CFG.WEAK_CLASS_WARN} (expect weaker/noisier recall):\")\n        for cnt, name in weak[:10]:\n            print(f\"      {cnt:>4}  {name}\")\n        if len(weak) > 10:\n            print(f\"      … and {len(weak) - 10} more\")\n\n    return all_samples, classes, class_to_idx\n\n\n# ════════════════════════════════════════════════════════════\n# 6.  TRANSFORMS  [FIX-5] [FIX-6] [FIX-19]\n#     train: RandomResizedCrop (aspect-aware) + augments\n#     val/test: Resize(256) + CenterCrop(224) (aspect-preserving)\n# ════════════════════════════════════════════════════════════\ndef build_transforms():\n    processor = get_processor(CFG.MODEL_NAME)\n    mean, std = processor.image_mean, processor.image_std\n    size      = CFG.IMAGE_SIZE\n    resize_to = int(size * 256 / 224)          # 256 for a 224 crop\n\n    train_tf = transforms.Compose([\n        # [FIX-19] RandomResizedCrop preserves aspect ratio and adds scale\n        # augmentation; the old Resize((224,224)) squashed every image.\n        transforms.RandomResizedCrop(size, scale=(0.7, 1.0), ratio=(0.75, 1.333)),\n        transforms.RandomHorizontalFlip(p=0.5),\n        # [FIX-19] RandomVerticalFlip removed — pots/soil belong at the bottom.\n        transforms.RandomRotation(degrees=30),\n        transforms.RandomPerspective(distortion_scale=0.2, p=0.3),\n        transforms.ColorJitter(\n            brightness=0.3, contrast=0.3, saturation=0.3, hue=0.05\n        ),\n        transforms.RandomGrayscale(p=0.05),\n        transforms.ToTensor(),\n        transforms.Normalize(mean=mean, std=std),\n        # value='random' fills with noise, not normalized black, so the model\n        # can't learn to ignore a fixed-color erased region.\n        transforms.RandomErasing(p=0.1, scale=(0.02, 0.1), value=\"random\"),\n    ])\n\n    val_tf = transforms.Compose([\n        # [FIX-19] Aspect-preserving: shorter side → 256, then centre 224 crop.\n        transforms.Resize(resize_to),\n        transforms.CenterCrop(size),\n        transforms.ToTensor(),\n        transforms.Normalize(mean=mean, std=std),\n    ])\n\n    return train_tf, val_tf\n\n\n# [FIX-24] Module-level cached val transform — predict() reuses this instead\n# of rebuilding transforms.Compose() (8+ objects) on every inference call.\n_VAL_TF = None\n\n\ndef get_val_transform():\n    global _VAL_TF\n    if _VAL_TF is None:\n        _, _VAL_TF = build_transforms()\n    return _VAL_TF\n\n\n# ════════════════════════════════════════════════════════════\n# 7.  SPLITS & DATALOADERS\n# ════════════════════════════════════════════════════════════\ndef build_dataloaders(data_dir: str):\n    print(\"\\n📂 Building datasets...\")\n\n    all_samples, classes, class_to_idx = scan_dataset(data_dir)\n    train_tf, val_tf = build_transforms()\n\n    all_labels = [lbl for _, lbl in all_samples]\n    indices    = list(range(len(all_samples)))\n\n    # ── Stratified 70 / 15 / 15 split ─────────────────────────\n    temp_ratio = CFG.VAL_RATIO + CFG.TEST_RATIO\n    train_idx, temp_idx = train_test_split(\n        indices, test_size=temp_ratio,\n        random_state=CFG.SEED, stratify=all_labels,\n    )\n    temp_labels = [all_labels[i] for i in temp_idx]\n    rel_test    = CFG.TEST_RATIO / temp_ratio\n    val_idx, test_idx = train_test_split(\n        temp_idx, test_size=rel_test,\n        random_state=CFG.SEED, stratify=temp_labels,\n    )\n\n    print(f\"✂️  Split → Train: {len(train_idx)} | \"\n          f\"Val: {len(val_idx)} | Test: {len(test_idx)}\")\n\n    def make_ds(idx_list, transform):\n        samples = [all_samples[i] for i in idx_list]\n        return PlantDataset(samples, transform, classes, class_to_idx)\n\n    train_ds = make_ds(train_idx, train_tf)\n    val_ds   = make_ds(val_idx,   val_tf)\n    test_ds  = make_ds(test_idx,  val_tf)\n\n    # ── WeightedRandomSampler — corrects class imbalance ───────\n    train_labels   = [s[1] for s in train_ds.samples]\n    class_counts   = np.bincount(train_labels, minlength=len(classes))\n    # guard against any zero-count class (avoids inf weights)\n    class_counts   = np.clip(class_counts, 1, None).astype(np.float32)\n    class_weights  = 1.0 / class_counts\n    sample_weights = class_weights[train_labels]\n\n    sampler = WeightedRandomSampler(\n        weights=torch.tensor(sample_weights, dtype=torch.float),\n        num_samples=len(sample_weights),\n        replacement=True,\n    )\n    print(f\"⚖️  WeightedRandomSampler active — \"\n          f\"{len(sample_weights)} samples/epoch\")\n\n    pin = (DEVICE_TYPE == \"gpu\")\n\n    # [FIX-22] persistent_workers/prefetch_factor are only valid (and only\n    # help) when num_workers > 0 — i.e. GPU/CPU, not TPU (where workers=0).\n    # Passing prefetch_factor with num_workers=0 raises on some torch builds,\n    # so we add them conditionally.\n    worker_kwargs = (\n        dict(persistent_workers=True, prefetch_factor=2)\n        if NUM_WORKERS > 0 else {}\n    )\n\n    # sampler is mutually exclusive with shuffle=True\n    train_cpu = DataLoader(\n        train_ds,\n        batch_size=CFG.BATCH_SIZE,\n        sampler=sampler,\n        num_workers=NUM_WORKERS,\n        pin_memory=pin,\n        drop_last=True,          # prevents XLA recompilation on last batch\n        **worker_kwargs,\n    )\n    val_cpu = DataLoader(\n        val_ds,\n        batch_size=CFG.BATCH_SIZE,\n        shuffle=False,\n        num_workers=NUM_WORKERS,\n        pin_memory=pin,\n        **worker_kwargs,\n    )\n    test_cpu = DataLoader(\n        test_ds,\n        batch_size=CFG.BATCH_SIZE,\n        shuffle=False,\n        num_workers=NUM_WORKERS,\n        pin_memory=pin,\n        **worker_kwargs,\n    )\n\n    # ── Wrap for TPU ───────────────────────────────────────────\n    if DEVICE_TYPE == \"tpu\":\n        train_loader = MpDeviceLoader(train_cpu, DEVICE)\n        val_loader   = MpDeviceLoader(val_cpu,   DEVICE)\n        test_loader  = MpDeviceLoader(test_cpu,  DEVICE)\n    else:\n        train_loader = train_cpu\n        val_loader   = val_cpu\n        test_loader  = test_cpu\n\n    meta = {\n        \"classes\":      classes,\n        \"class_to_idx\": class_to_idx,\n        \"num_classes\":  len(classes),\n    }\n\n    return (\n        train_loader, val_loader, test_loader,\n        train_cpu,    val_cpu,    test_cpu,\n        meta,\n    )\n\n\n# ════════════════════════════════════════════════════════════\n# 8.  MODEL — freeze / unfreeze helpers\n# ════════════════════════════════════════════════════════════\ndef _attach_head_dropout(model, p: float):\n    \"\"\"\n    [FIX-25] Insert dropout on the CLS embedding feeding the classifier,\n    via a forward-pre-hook. nn.Dropout has no params/buffers, so the saved\n    state_dict and from_pretrained() export stay byte-identical to a plain\n    ViTForImageClassification. Dropout respects model.train()/eval(), so it\n    is a no-op at inference — the app loads the standard class unchanged.\n    \"\"\"\n    if not p or p <= 0:\n        return\n    # Registering as an attribute auto-adds it as a submodule, so\n    # model.train()/eval() propagates the training flag to it.\n    model.head_dropout = nn.Dropout(p)\n\n    def _pre_hook(module, args):\n        if not args:\n            return None\n        return (model.head_dropout(args[0]),) + tuple(args[1:])\n\n    model.classifier.register_forward_pre_hook(_pre_hook)\n    print(f\"🎲 Head dropout attached (p={p}) — active in train, off in eval.\")\n\n\ndef build_model(num_classes: int, classes: list):\n    print(f\"\\n🧠 Loading {CFG.MODEL_NAME} ...\")\n    model = ViTForImageClassification.from_pretrained(\n        CFG.MODEL_NAME,\n        num_labels=num_classes,\n        ignore_mismatched_sizes=True,\n        # [FIX-15] int keys/values — label2id must map label→int, not str.\n        id2label={i: c for i, c in enumerate(classes)},\n        label2id={c: i for i, c in enumerate(classes)},\n    )\n    _attach_head_dropout(model, CFG.HEAD_DROPOUT)   # [FIX-25]\n    return model.to(DEVICE)\n\n\ndef freeze_backbone(model):\n    for p in model.vit.parameters():\n        p.requires_grad = False\n    for p in model.classifier.parameters():\n        p.requires_grad = True\n    n = sum(p.numel() for p in model.parameters() if p.requires_grad)\n    print(f\"❄️  Backbone frozen  — trainable params: {n:,}\")\n\n\ndef unfreeze_all(model):\n    for p in model.parameters():\n        p.requires_grad = True\n    n = sum(p.numel() for p in model.parameters() if p.requires_grad)\n    print(f\"🔥 Full unfreeze    — trainable params: {n:,}\")\n\n\ndef build_optimizer(model, stage: int):\n    if stage == 1:\n        return AdamW(\n            filter(lambda p: p.requires_grad, model.parameters()),\n            lr=CFG.HEAD_LR,\n            weight_decay=CFG.WEIGHT_DECAY,\n        )\n    # Stage 2: differential learning rates — backbone gets 10× lower LR\n    return AdamW(\n        [\n            {\"params\": model.vit.parameters(),        \"lr\": CFG.BACKBONE_LR},\n            {\"params\": model.classifier.parameters(), \"lr\": CFG.HEAD_LR},\n        ],\n        weight_decay=CFG.WEIGHT_DECAY,\n    )\n\n\n# ════════════════════════════════════════════════════════════\n# 9.  FORWARD PASS  — precision per device  [FIX-9] [FIX-18]\n# ════════════════════════════════════════════════════════════\ndef _forward(model, images, labels, criterion):\n    if USE_AMP:\n        with amp_autocast():                       # [FIX-18] modern API\n            logits = model(pixel_values=images).logits\n            loss   = criterion(logits, labels)\n    else:\n        # TPU: XLA_USE_BF16 already active. CPU: float32.\n        logits = model(pixel_values=images).logits\n        loss   = criterion(logits, labels)\n    return logits, loss\n\n\n# ════════════════════════════════════════════════════════════\n# 10.  TRAIN — one epoch  [FIX-2] [FIX-4] [FIX-13] [FIX-16] [FIX-17]\n# ════════════════════════════════════════════════════════════\ndef train_one_epoch(model, loader, loader_cpu, optimizer,\n                    scheduler, criterion, epoch, total_epochs):\n    model.train()\n\n    # [FIX-2] Accumulate on the device tensor — no per-batch .item() sync.\n    running_loss  = torch.tensor(0.0, device=DEVICE)\n    train_correct = torch.tensor(0,   device=DEVICE)\n    train_total   = torch.tensor(0,   device=DEVICE)\n\n    pbar = tqdm(loader, total=len(loader_cpu),\n                desc=f\"Epoch {epoch:02d}/{total_epochs} [Train]\")\n\n    for images, labels in pbar:\n        if DEVICE_TYPE != \"tpu\":\n            images = images.to(DEVICE, non_blocking=True)\n            labels = labels.to(DEVICE, non_blocking=True)\n\n        optimizer.zero_grad()\n        logits, loss = _forward(model, images, labels, criterion)\n\n        if USE_AMP:\n            scaler.scale(loss).backward()\n            scaler.unscale_(optimizer)\n            torch.nn.utils.clip_grad_norm_(model.parameters(), CFG.GRAD_CLIP)\n            # [FIX-17] detect a skipped step (inf/nan) so we don't advance\n            # the LR schedule past an optimizer step that never happened.\n            scale_before = scaler.get_scale()\n            scaler.step(optimizer)\n            scaler.update()\n            stepped = scaler.get_scale() >= scale_before\n            if stepped:\n                scheduler.step()\n        else:\n            loss.backward()\n            torch.nn.utils.clip_grad_norm_(model.parameters(), CFG.GRAD_CLIP)\n            if DEVICE_TYPE == \"tpu\":\n                # barrier=True = optimizer.step() + mark_step() in one call.\n                xm.optimizer_step(optimizer, barrier=True)\n            else:\n                optimizer.step()\n            scheduler.step()\n\n        # [FIX-16] sample-weighted loss sum (loss is a per-batch mean).\n        bs = labels.size(0)\n        running_loss  += loss.detach() * bs\n        _, predicted   = logits.max(1)\n        train_correct += predicted.eq(labels).sum()\n        train_total   += bs\n\n        # [FIX-13] On TPU, NEVER call .item() inside the loop — it forces a\n        # device sync every step and undoes FIX-2. Show the bar only.\n        if DEVICE_TYPE != \"tpu\":\n            pbar.set_postfix({\n                \"acc\": f\"{100.0 * train_correct.item() / max(train_total.item(), 1):.1f}%\"\n            })\n\n    if DEVICE_TYPE == \"tpu\":\n        xm.mark_step()\n\n    # Single sync at epoch end.\n    avg_loss = (running_loss / train_total).item()\n    accuracy = 100.0 * train_correct.item() / train_total.item()\n    return avg_loss, accuracy\n\n\n# ════════════════════════════════════════════════════════════\n# 11.  EVALUATE — validation and test  [FIX-2] [FIX-9] [FIX-16]\n# ════════════════════════════════════════════════════════════\n@torch.no_grad()\ndef evaluate(model, loader, loader_cpu, criterion, desc=\"Val\"):\n    model.eval()\n\n    running_loss = torch.tensor(0.0, device=DEVICE)\n    correct      = torch.tensor(0,   device=DEVICE)\n    total        = torch.tensor(0,   device=DEVICE)\n\n    all_preds, all_labels = [], []\n\n    for images, labels in tqdm(loader, total=len(loader_cpu), desc=desc):\n        if DEVICE_TYPE != \"tpu\":\n            images = images.to(DEVICE, non_blocking=True)\n            labels = labels.to(DEVICE, non_blocking=True)\n\n        logits, loss = _forward(model, images, labels, criterion)\n\n        # [FIX-23] No per-batch xm.mark_step() here — the .cpu() calls below\n        # already materialize each batch; one mark_step after the loop is\n        # enough (matches train_one_epoch).\n        bs = labels.size(0)\n        running_loss += loss.detach() * bs          # [FIX-16]\n        _, predicted  = logits.max(1)\n        total        += bs\n        correct      += predicted.eq(labels).sum()\n\n        all_preds.extend(predicted.cpu().numpy())\n        all_labels.extend(labels.cpu().numpy())\n\n    if DEVICE_TYPE == \"tpu\":\n        xm.mark_step()\n\n    avg_loss = (running_loss / total).item()\n    accuracy = 100.0 * correct.item() / total.item()\n    return avg_loss, accuracy, all_preds, all_labels\n\n\n# ════════════════════════════════════════════════════════════\n# 12.  CHECKPOINTS  [FIX-11] [FIX-12] [FIX-14]\n#\n#  BEST_CKPT  (pytorch_model.bin)   : payload dict, best weights for eval.\n#  LAST_CKPT  (last_checkpoint.bin) : full state every epoch, for resume.\n#  EXPORT_DIR (hf_export/)          : clean HuggingFace artifact for the app.\n# ════════════════════════════════════════════════════════════\ndef _save(payload, path):\n    if DEVICE_TYPE == \"tpu\":\n        xm.save(payload, path)\n    else:\n        torch.save(payload, path)\n\n\ndef save_best_checkpoint(model, meta, epoch, stage, best_val_acc):\n    os.makedirs(CFG.OUTPUT_DIR, exist_ok=True)\n    _save({\n        \"epoch\":        epoch,\n        \"stage\":        stage,\n        \"best_val_acc\": best_val_acc,\n        \"model\":        model.state_dict(),\n    }, BEST_CKPT)\n\n    model.config.save_pretrained(CFG.OUTPUT_DIR)\n    with open(f\"{CFG.OUTPUT_DIR}/class_names.json\", \"w\") as f:\n        json.dump({str(i): c for i, c in enumerate(meta[\"classes\"])}, f, indent=2)\n\n\ndef save_last_checkpoint(model, optimizer, scheduler,\n                         epoch, stage, best_val_acc):\n    \"\"\"[FIX-14] Full training state written EVERY epoch for exact resume.\"\"\"\n    os.makedirs(CFG.OUTPUT_DIR, exist_ok=True)\n    _save({\n        \"epoch\":        epoch,\n        \"stage\":        stage,\n        \"best_val_acc\": best_val_acc,\n        \"model\":        model.state_dict(),\n        \"optimizer\":    optimizer.state_dict() if optimizer else None,\n        \"scheduler\":    scheduler.state_dict() if scheduler else None,\n    }, LAST_CKPT)\n\n\ndef load_checkpoint(model, path=BEST_CKPT):\n    \"\"\"Inference path — loads model weights only.\n    map_location='cpu' is intentional: xm.save() tags tensors as xla:0,\n    which torch.load() cannot remap directly to an XLA device.\"\"\"\n    payload = torch.load(path, map_location=\"cpu\")\n    state   = payload[\"model\"] if isinstance(payload, dict) and \"model\" in payload else payload\n    model.load_state_dict(state)\n    model.to(DEVICE)\n    print(f\"  ✅ Checkpoint loaded: {path}\")\n\n\ndef read_resume_state():\n    \"\"\"[FIX-14] Read the 'last' checkpoint metadata + raw payload for resume.\"\"\"\n    if not os.path.exists(LAST_CKPT):\n        return None\n    payload = torch.load(LAST_CKPT, map_location=\"cpu\")\n    if not isinstance(payload, dict) or \"model\" not in payload:\n        return None\n    return payload\n\n\n# ════════════════════════════════════════════════════════════\n# 13.  TRAINING ORCHESTRATOR  [FIX-3] [FIX-14]\n# ════════════════════════════════════════════════════════════\ndef run_stage(\n    stage, model, stage_total_epochs, start_epoch, end_epoch,\n    train_loader, val_loader, train_cpu, val_cpu,\n    criterion, meta, history,\n    best_val_acc, patience_count,\n    resume_opt_state=None, resume_sched_state=None,\n):\n    desc = (\"Head only (backbone frozen)\"\n            if stage == 1 else\n            \"Full fine-tune (differential LRs)\")\n    print(f\"\\n{'═'*58}\")\n    print(f\"  STAGE {stage} — {desc}\")\n    print(f\"{'═'*58}\")\n\n    optimizer    = build_optimizer(model, stage)\n    # total_steps is computed from the FULL stage length so a resumed\n    # scheduler lines up with the original cosine schedule.\n    total_steps  = len(train_cpu) * stage_total_epochs\n    warmup_steps = max(1, int(total_steps * CFG.WARMUP_RATIO))\n    scheduler    = get_cosine_schedule_with_warmup(\n        optimizer,\n        num_warmup_steps=warmup_steps,\n        num_training_steps=total_steps,\n    )\n\n    # [FIX-14] Restore optimizer/scheduler position when resuming mid-stage.\n    if resume_opt_state is not None:\n        optimizer.load_state_dict(resume_opt_state)\n        print(\"  ↩️  Optimizer state restored.\")\n    if resume_sched_state is not None:\n        scheduler.load_state_dict(resume_sched_state)\n        print(\"  ↩️  Scheduler state restored.\")\n\n    for epoch in range(start_epoch, end_epoch + 1):\n        t_loss, t_acc = train_one_epoch(\n            model, train_loader, train_cpu,\n            optimizer, scheduler, criterion,\n            epoch, CFG.TOTAL_EPOCHS,\n        )\n        v_loss, v_acc, _, _ = evaluate(\n            model, val_loader, val_cpu, criterion,\n        )\n\n        print(\n            f\"\\n  [S{stage}] Epoch {epoch:02d} | \"\n            f\"T-Loss: {t_loss:.4f}  T-Acc: {t_acc:.2f}% | \"\n            f\"V-Loss: {v_loss:.4f}  V-Acc: {v_acc:.2f}%\"\n        )\n\n        history.append({\n            \"epoch\":      epoch,\n            \"stage\":      stage,\n            \"train_loss\": round(t_loss, 5),\n            \"train_acc\":  round(t_acc,  3),\n            \"val_loss\":   round(v_loss, 5),\n            \"val_acc\":    round(v_acc,  3),\n        })\n\n        # [FIX-14] Save 'last' every epoch — exact resume point on crash.\n        save_last_checkpoint(model, optimizer, scheduler,\n                             epoch=epoch, stage=stage, best_val_acc=best_val_acc)\n\n        if v_acc > best_val_acc:\n            best_val_acc   = v_acc\n            patience_count = 0\n            save_best_checkpoint(model, meta, epoch, stage, best_val_acc)\n            print(f\"  ✅ New best: {v_acc:.2f}% — best checkpoint saved.\")\n        else:\n            patience_count += 1\n            print(f\"  ⏳ No improvement — \"\n                  f\"patience {patience_count}/{CFG.PATIENCE}\")\n            if stage == 2 and patience_count >= CFG.PATIENCE:\n                print(\"  🛑 Early stopping triggered.\")\n                break\n\n    return best_val_acc, patience_count\n\n\ndef train(model, loaders, meta, resume=None):\n    # Explicit 7-tuple unpack — no silent star-unpack\n    (\n        train_loader, val_loader, _test_loader,\n        train_cpu,    val_cpu,    _test_cpu,\n        _meta,\n    ) = loaders\n\n    criterion      = nn.CrossEntropyLoss(label_smoothing=CFG.LABEL_SMOOTHING)\n    history        = []\n    best_val_acc   = 0.0\n    patience_count = 0\n\n    # ── Resume bookkeeping  [FIX-14] ──────────────────────────\n    resumed_stage = resumed_epoch = 0\n    r_opt = r_sched = None\n    if resume is not None:\n        resumed_stage = resume.get(\"stage\", 0)\n        resumed_epoch = resume.get(\"epoch\", 0)        # last COMPLETED epoch\n        best_val_acc  = resume.get(\"best_val_acc\", 0.0)\n        r_opt, r_sched = resume.get(\"optimizer\"), resume.get(\"scheduler\")\n        model.load_state_dict(resume[\"model\"]); model.to(DEVICE)\n        print(f\"  ↩️  Resuming from stage {resumed_stage}, \"\n              f\"epoch {resumed_epoch}, best {best_val_acc:.2f}%\")\n\n    stage1_done = resumed_stage >= 2 or resumed_epoch >= CFG.STAGE1_EPOCHS\n\n    # ── Stage 1: frozen backbone ──────────────────────────────\n    if not stage1_done:\n        freeze_backbone(model)\n        s1_start = resumed_epoch + 1 if resumed_stage == 1 else 1\n        best_val_acc, patience_count = run_stage(\n            stage=1, model=model,\n            stage_total_epochs=CFG.STAGE1_EPOCHS,\n            start_epoch=s1_start, end_epoch=CFG.STAGE1_EPOCHS,\n            train_loader=train_loader, val_loader=val_loader,\n            train_cpu=train_cpu, val_cpu=val_cpu,\n            criterion=criterion, meta=meta, history=history,\n            best_val_acc=best_val_acc, patience_count=patience_count,\n            resume_opt_state=r_opt   if resumed_stage == 1 else None,\n            resume_sched_state=r_sched if resumed_stage == 1 else None,\n        )\n        # consume resume state so it isn't reused in stage 2\n        r_opt = r_sched = None\n\n    # ── Stage 2: full fine-tune ───────────────────────────────\n    unfreeze_all(model)\n    # Patience MUST be reset to 0 at Stage 2 start. Carrying S1 patience in\n    # would trigger early stopping far too soon.\n    s2_start = (resumed_epoch + 1\n                if resumed_stage == 2\n                else CFG.STAGE1_EPOCHS + 1)\n    best_val_acc, _ = run_stage(\n        stage=2, model=model,\n        stage_total_epochs=CFG.STAGE2_EPOCHS,\n        start_epoch=s2_start, end_epoch=CFG.TOTAL_EPOCHS,\n        train_loader=train_loader, val_loader=val_loader,\n        train_cpu=train_cpu, val_cpu=val_cpu,\n        criterion=criterion, meta=meta, history=history,\n        best_val_acc=best_val_acc,\n        patience_count=0,\n        resume_opt_state=r_opt   if resumed_stage == 2 else None,\n        resume_sched_state=r_sched if resumed_stage == 2 else None,\n    )\n\n    with open(CFG.LOG_FILE, \"w\") as f:\n        json.dump(history, f, indent=2)\n    print(f\"\\n📝 Training log saved → {CFG.LOG_FILE}\")\n\n    return best_val_acc\n\n\n# ════════════════════════════════════════════════════════════\n# 14.  FINAL TEST EVALUATION  [FIX-7]\n# ════════════════════════════════════════════════════════════\ndef final_test(model, test_loader, test_cpu, meta):\n    print(\"\\n\" + \"═\"*58)\n    print(\"  FINAL TEST EVALUATION\")\n    print(\"═\"*58)\n\n    load_checkpoint(model, BEST_CKPT)        # best weights\n\n    criterion = nn.CrossEntropyLoss(label_smoothing=CFG.LABEL_SMOOTHING)\n    _, test_acc, preds, labels = evaluate(\n        model, test_loader, test_cpu, criterion, desc=\"Test\",\n    )\n\n    print(f\"\\n  🎯 Test Accuracy: {test_acc:.2f}%\")\n\n    class_names = [meta[\"classes\"][i] for i in range(meta[\"num_classes\"])]\n\n    # zero_division=0 avoids UndefinedMetricWarning when a rare class\n    # receives no predictions in a small test set.\n    report = classification_report(\n        labels, preds,\n        target_names=class_names,\n        digits=3,\n        zero_division=0,\n    )\n    print(\"\\n  📋 Per-Class Report:\\n\")\n    print(report)\n\n    cm = confusion_matrix(labels, preds)\n    np.save(f\"{CFG.OUTPUT_DIR}/confusion_matrix.npy\", cm)\n    print(f\"  💾 Confusion matrix → {CFG.OUTPUT_DIR}/confusion_matrix.npy\")\n\n    return test_acc\n\n\n# ════════════════════════════════════════════════════════════\n# 15.  HUGGINGFACE EXPORT FOR THE APP  [FIX-12]\n#      Writes a clean, from_pretrained()-loadable artifact:\n#      config.json + model weights + processor preprocessor_config.json.\n# ════════════════════════════════════════════════════════════\ndef export_for_app(model):\n    os.makedirs(CFG.EXPORT_DIR, exist_ok=True)\n\n    # On TPU, move to CPU so save_pretrained writes plain CPU tensors.\n    model_to_save = model.to(\"cpu\") if DEVICE_TYPE == \"tpu\" else model\n    model_to_save.save_pretrained(CFG.EXPORT_DIR)        # config.json + weights\n    get_processor(CFG.MODEL_NAME).save_pretrained(CFG.EXPORT_DIR)  # mean/std/size\n\n    print(f\"\\n📦 App-ready model exported → {CFG.EXPORT_DIR}\")\n    print(\"   Load in your app with:\")\n    print(\"     ViTForImageClassification.from_pretrained(EXPORT_DIR)\")\n    print(\"     ViTImageProcessor.from_pretrained(EXPORT_DIR)\")\n\n\n# ════════════════════════════════════════════════════════════\n# 16.  PRODUCTION INFERENCE  [FIX-6] [FIX-10]\n#      Mirrors val preprocessing exactly. Drop into FastAPI as-is.\n# ════════════════════════════════════════════════════════════\ndef predict(image_path: str, model, class_names: dict, top_k: int = 5):\n    \"\"\"\n    Args:\n        image_path : path to image file\n        model      : loaded ViTForImageClassification (eval mode)\n        class_names: dict {str(idx): class_name} from class_names.json\n        top_k      : number of top predictions to return\n    Returns:\n        list of (class_name, confidence_percent) sorted by confidence\n    \"\"\"\n    val_tf = get_val_transform()             # [FIX-24] cached — no rebuild/network\n    image  = Image.open(image_path).convert(\"RGB\")\n    tensor = val_tf(image).unsqueeze(0).to(DEVICE)\n\n    model.eval()\n    with torch.no_grad():\n        logits = model(pixel_values=tensor).logits\n    probs          = torch.softmax(logits, dim=1)[0]\n    k              = min(top_k, probs.size(0))\n    top_p, top_idx = probs.topk(k)\n\n    return [\n        (class_names[str(i.item())], round(p.item() * 100, 2))\n        for p, i in zip(top_p, top_idx)\n    ]\n\n\n# ════════════════════════════════════════════════════════════\n# 17.  ENTRY POINT\n# ════════════════════════════════════════════════════════════\nif __name__ == \"__main__\":\n    t0 = time.time()\n\n    print(\"=\" * 58)\n    print(\"  GardenMate — ViT Plant Species Classifier  v6.1\")\n    print(\"=\" * 58)\n    print(f\"  Device      : {DEVICE_TYPE.upper()}\")\n    print(f\"  BF16 (TPU)  : {os.environ.get('XLA_USE_BF16', '0')}\")\n    print(f\"  FP16 (GPU)  : {USE_AMP}\")\n    print(f\"  Num workers : {NUM_WORKERS}\")\n    print(f\"  Max/class   : {CFG.MAX_PER_CLASS}\")\n    print(f\"  Min/class   : {CFG.MIN_PER_CLASS}\")\n    print(f\"  Head dropout: {CFG.HEAD_DROPOUT}\")\n    print(f\"  Skip train  : {CFG.SKIP_TRAINING}\")\n    print(f\"  Resume      : {CFG.RESUME}\")\n    print(\"=\" * 58)\n\n    # Step 1: resolve data path safely\n    data_dir = resolve_data_dir(CFG.DATA_BASE)\n\n    # Step 2: build data pipeline (always needed — test_loader lives here)\n    loaders = build_dataloaders(data_dir)\n    (\n        train_loader, val_loader, test_loader,\n        train_cpu,    val_cpu,    test_cpu,\n        meta,\n    ) = loaders\n\n    # Step 3: build model architecture (always needed before loading weights)\n    model = build_model(meta[\"num_classes\"], meta[\"classes\"])\n\n    if CFG.SKIP_TRAINING:\n        print(\"\\n⏭️  SKIP_TRAINING=True — loading best checkpoint, skipping training.\")\n        best_acc = None\n    else:\n        resume_payload = read_resume_state() if CFG.RESUME else None\n        if CFG.RESUME and resume_payload is None:\n            print(\"\\n⚠️  RESUME=True but no usable 'last' checkpoint — training fresh.\")\n        best_acc = train(model, loaders, meta, resume=resume_payload)\n\n    # Step 4: final test on held-out set with best weights\n    test_acc = final_test(model, test_loader, test_cpu, meta)\n\n    # Step 5: export a clean, app-loadable artifact  [FIX-12]\n    export_for_app(model)\n\n    elapsed = time.time() - t0\n    print(f\"\\n{'='*58}\")\n    print(f\"  ⏱️  Total time : {elapsed / 60:.1f} min\")\n    if best_acc is not None:\n        print(f\"  🏆 Best Val   : {best_acc:.2f}%\")\n    print(f\"  🎯 Test Acc   : {test_acc:.2f}%\")\n    print(f\"  📁 Saved to   : {CFG.OUTPUT_DIR}/\")\n    print(f\"  📦 App model  : {CFG.EXPORT_DIR}/\")\n    print(\"=\"*58)\n    \n    # Verify outputs exist before session ends\n    from pathlib import Path\n    critical = [\n        \"/kaggle/working/gardenmate_model/pytorch_model.bin\",\n        \"/kaggle/working/gardenmate_model/hf_export\",\n    ]\n    for p in critical:\n        assert Path(p).exists(), f\"MISSING: {p} — do not close session yet!\"\n    print(\"✅ All critical outputs verified — safe to commit.\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null}]}